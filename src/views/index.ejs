<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inveenda Store</title>

  <link rel="stylesheet" href="/stylesheets/includes/header.css">

  <link rel="stylesheet" href="/stylesheets/pages/index.css">
</head>
<body>
  <%- include("includes/header.ejs") %>
    <main class="store">
      <section class="hero">
        <h1>Inveenda Store</h1>
        
      </section>
      <section class="products">
        <% if(products && products.length> 0){ %>
          <% products.forEach(p=>{ %>
            <div class="card">
              <div class="card-image">
                <img src="<%= p.image || '/images/default.png' %>">
              </div>
              <div class="card-body">
                <h3>
                  <%= p.name %>
                </h3>
                <p class="description">
                  <%= p.description || "Sin descripción" %>
                </p>
                <div class="card-footer">
                  <span class="price">$<%= p.price %></span>
                  <span class="stock">Stock: <%= p.stock %></span>
                </div>
              </div>
            </div>
            <% }) %>
              <% } else { %>
                <p class="empty">No hay productos disponibles en este momento</p>
                <% } %>
      </section>
    </main>
</body>
</html>
