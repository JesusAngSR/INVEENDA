<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Dashboard</title>

    <link rel="stylesheet" href="/stylesheets/includes/header.css">
    
    <link rel="stylesheet" href="/stylesheets/pages/dashboard.css">
</head>
<body>
    <%- include("../includes/header.ejs") %>
    <main class="dashboard">
        <h1>Dashboard de productos</h1>
        <a href="/dashboard/create" class="add-btn">+ Agregar producto</a>
        <table>
            <thead>
                <tr>
                    <th>Imagen</th>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Stock</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% if(products && products.length > 0){ %>
                    <% products.forEach(p=>{ %>
                        <tr>
                            <td><img src="<%= p.image || '/images/default.png' %>"></td>
                            <td><%= p.name %></td>
                            <td>$<%= p.price %></td>
                            <td><%= p.stock %></td>
                            <td class="actions">
                                <a class="edit-btn" href="/dashboard/edit/<%= p._id %>">Editar</a>
                                <a class="delete-btn" href="/dashboard/delete/<%= p._id %>">Eliminar</a>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="5">No hay productos registrados</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </main>
</body>
</html>
